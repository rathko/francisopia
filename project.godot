; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Francis-opia"
config/description="A cozy reading adventure where words have magical power"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.png"

[autoload]

Events="*res://scripts/autoload/Events.gd"
GameManager="*res://scripts/autoload/GameManager.gd"
WordEngine="*res://scripts/autoload/WordEngine.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
InputHelper="*res://scripts/autoload/InputHelper.gd"
QuestGenerator="*res://scripts/autoload/QuestGenerator.gd"
MagicSummon="*res://scripts/autoload/MagicSummon.gd"
MagicVFX="*res://scripts/autoload/MagicVFX.gd"
SoundFX="*res://scripts/autoload/SoundFX.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=800
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://assets/ui/game_theme.tres"
theme/default_font_size=32

