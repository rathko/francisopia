; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited via text.

[application]

config/name="Francis-opia"
config/description="A cozy reading adventure where words have magical power"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://icon.png"

[autoload]

Events="*res://scripts/autoload/Events.gd"
GameManager="*res://scripts/autoload/GameManager.gd"
WordEngine="*res://scripts/autoload/WordEngine.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
InputHelper="*res://scripts/autoload/InputHelper.gd"
QuestGenerator="*res://scripts/autoload/QuestGenerator.gd"
MagicSummon="*res://scripts/autoload/MagicSummon.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=800
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

[gui]

theme/default_font_size=32

